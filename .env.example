# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SESSION_SECRET: Secret key used to sign session (Bearer) tokens.
# Set this to a long random string (e.g. `openssl rand -hex 32`) in production.
# If unset, an ephemeral secret is generated per-process and all sessions are
# invalidated on restart.
SESSION_SECRET=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PRODUCTION SUPABASE CONFIGURATION
# Set these to connect Void Coding to your real Supabase database and Auth.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# PRODUCTION OPENAI CONFIGURATION
# Set this to use real OpenAI GPT-4o for code reviews, mentorship, and project assistant.
OPENAI_API_KEY=""

# PRODUCTION RAZORPAY CONFIGURATION
# Set these to process real student subscription payments via your Razorpay account.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# PRODUCTION SMTP EMAIL CONFIGURATION
# Set these to send real transaction and lifecycle emails to users.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Void Compliance <noreply@voidcoding.com>"

