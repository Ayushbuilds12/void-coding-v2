rules_version = '2';

// Void Studios Firestore security rules.
// All application access goes through the server (Firebase Admin SDK), which
// bypasses these rules. They exist as defense-in-depth so that direct client
// access is locked down: a user may only read their own records, and writes are
// disallowed from the client entirely (the server is the only writer).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function ownsResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Users: a user can read only their own user document.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // Owned collections: read-your-own, no client writes.
    match /projects/{docId}      { allow read: if ownsResource(); allow write: if false; }
    match /websites/{docId}      { allow read: if ownsResource(); allow write: if false; }
    match /ads/{docId}           { allow read: if ownsResource(); allow write: if false; }
    match /brands/{docId}        { allow read: if ownsResource(); allow write: if false; }
    match /subscriptions/{docId} { allow read: if ownsResource(); allow write: if false; }
    match /payments/{docId}      { allow read: if ownsResource(); allow write: if false; }
    match /invoices/{docId}      { allow read: if ownsResource(); allow write: if false; }

    // Audit logs are server-only.
    match /activity_logs/{docId} { allow read, write: if false; }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
